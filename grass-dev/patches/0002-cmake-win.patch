From 80c8d045fce079086fc9c3a4faea09cd4bfe2469 Mon Sep 17 00:00:00 2001
From: Huidae Cho <grass4u@gmail.com>
Date: Tue, 28 Apr 2026 18:23:01 -0600
Subject: [PATCH 4/5] Install grass.bat in the correct path

---
 lib/init/CMakeLists.txt | 27 +++++++++++++++++----------
 1 file changed, 17 insertions(+), 10 deletions(-)

diff --git a/lib/init/CMakeLists.txt b/lib/init/CMakeLists.txt
index 1dbe583b1f1..c419573dab5 100644
--- a/lib/init/CMakeLists.txt
+++ b/lib/init/CMakeLists.txt
@@ -52,22 +52,29 @@ list(APPEND DLL_PATH_LIST ${DEPS_DLL_PATH})
 set(GRASS_PYDIR ${GRASS_INSTALL_PYDIR_RUNTIME_PATH})
 if(WIN32)
   configure_file(grass.py ${OUTDIR}/${GRASS_INSTALL_ETCDIR}/${START_UP} @ONLY)
-else()
-  configure_file(grass.py ${OUTDIR}/${CMAKE_INSTALL_BINDIR}/${START_UP} @ONLY)
-endif()
 
-set(GRASS_PYDIR ${GRASS_INSTALL_PYDIR_PATH})
-configure_file(grass.py ${CMAKE_CURRENT_BINARY_DIR}/${START_UP} @ONLY)
-unset(GRASS_PYDIR)
+  set(GRASS_PYDIR ${GRASS_INSTALL_PYDIR_PATH})
+  configure_file(grass.py ${CMAKE_CURRENT_BINARY_DIR}/${START_UP} @ONLY)
+  unset(GRASS_PYDIR)
 
-install(PROGRAMS ${CMAKE_CURRENT_BINARY_DIR}/${START_UP}
-        DESTINATION ${CMAKE_INSTALL_BINDIR})
+  install(PROGRAMS ${CMAKE_CURRENT_BINARY_DIR}/${START_UP}
+	  DESTINATION ${GRASS_INSTALL_ETCDIR})
 
-file(TO_NATIVE_PATH "${OUTDIR}/${GISBASE_DIR}" gisbase_init_dir)
+  file(TO_NATIVE_PATH ${GISBASE_DIR} gisbase_init_dir)
 
-if(WIN32)
   set(GRASS_PYTHON ${PYTHON_EXECUTABLE})
   configure_file(${script_input_file_name} ${OUTDIR}/${CMAKE_INSTALL_BINDIR}/${script_file_name} @ONLY)
+  install(PROGRAMS ${OUTDIR}/${CMAKE_INSTALL_BINDIR}/${script_file_name}
+          DESTINATION ${CMAKE_INSTALL_BINDIR})
+else()
+  configure_file(grass.py ${OUTDIR}/${CMAKE_INSTALL_BINDIR}/${START_UP} @ONLY)
+
+  set(GRASS_PYDIR ${GRASS_INSTALL_PYDIR_PATH})
+  configure_file(grass.py ${CMAKE_CURRENT_BINARY_DIR}/${START_UP} @ONLY)
+  unset(GRASS_PYDIR)
+
+  install(PROGRAMS ${CMAKE_CURRENT_BINARY_DIR}/${START_UP}
+          DESTINATION ${CMAKE_INSTALL_BINDIR})
 endif()
 
 file(TO_NATIVE_PATH ${OUTDIR}/${GRASS_INSTALL_BINDIR} grass_dll_dir)

From 4a9a920a903e9e2af958b39c39dd0cda725ebbb2 Mon Sep 17 00:00:00 2001
From: Huidae Cho <grass4u@gmail.com>
Date: Tue, 28 Apr 2026 18:24:17 -0600
Subject: [PATCH 5/5] Use %~dp0 rather than a full path in grass.bat.in for
 custom install path

---
 lib/init/grass.bat.in | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/lib/init/grass.bat.in b/lib/init/grass.bat.in
index 94399d1340c..5d24dfc8b9b 100644
--- a/lib/init/grass.bat.in
+++ b/lib/init/grass.bat.in
@@ -11,14 +11,14 @@ set GEOTIFF_CSV=@GEOTIFF_CSV@
 
 ::set FONTCONFIG_FILE=%GISBASE%\etc\fonts.conf
 
-set PATH=@gisbase_init_dir@\bin;@BINARY_DIR@;@DLL_PATH_LIST@;%PATH%
+set GISBASE=%~dp0\..\@gisbase_init_dir@
 
-set GISBASE=@gisbase_init_dir@
+set PATH=%GISBASE%\bin;@BINARY_DIR@;@DLL_PATH_LIST@;%PATH%
 
-set PYTHONPATH=@gisbase_init_dir@\etc\python;@gisbase_init_dir@\gui\wxpython;@gisbase_init_dir@\etc
+set PYTHONPATH=%GISBASE%\etc\python;%GISBASE%\gui\wxpython;%GISBASE%\etc
 
 set GRASS_PYTHON=@GRASS_PYTHON@
 
 set GRASS_CONFIG_DIR=@grass_config_dir@
 
-"@GRASS_PYTHON@" "@gisbase_init_dir@\etc\@START_UP@" %*
+"@GRASS_PYTHON@" "%GISBASE%\etc\@START_UP@" %*
